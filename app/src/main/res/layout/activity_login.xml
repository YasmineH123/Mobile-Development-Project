<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingTop="64dp"
        android:paddingBottom="40dp">

        <!-- Logo + Brand -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/baseline_delivery_dining_24"
            android:contentDescription="Delivery Icon"
            app:tint="@color/sky" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="FLY"
            android:textColor="@color/white"
            android:textSize="42sp"
            android:fontFamily="@font/poppins_bold"
            android:letterSpacing="0.2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="40dp"
            android:text="Hungry? We got you covered!"
            android:textColor="@color/light_blue"
            android:textSize="14sp"
            android:fontFamily="@font/poppins"
            android:gravity="center" />

        <!-- Login Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back"
                    android:textColor="@color/navy"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="24dp"
                    android:text="Sign in to continue"
                    android:textColor="@color/gray_text"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins" />

                <!-- Email field wrapper -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/input_field_bg"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        android:contentDescription="Email"
                        app:tint="@color/gray_text" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:hint="Email address"
                        android:inputType="textEmailAddress"
                        android:background="@null"
                        android:textColor="@color/navy"
                        android:textColorHint="@color/gray_text"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>

                <!-- Password field wrapper -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="28dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/gray_text"
                    app:boxStrokeColor="@color/pale_blue"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Password"
                        android:inputType="textPassword"
                        android:textColor="@color/navy"
                        android:textColorHint="@color/gray_text"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins"
                        android:paddingStart="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Sign In"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:backgroundTint="@color/navy"
                    android:textColor="@color/white"
                    app:cornerRadius="16dp" />

                <TextView
                    android:id="@+id/tvSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Don't have an account? Sign Up"
                    android:textColor="@color/ocean"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins"
                    android:gravity="center" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="16dp"
    android:layout_marginRight="16dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Product image -->
        <ImageView
            android:id="@+id/cartItemImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:background="@color/pale_blue"
            android:src="@drawable/ic_home" />

        <!-- Name / price / quantity controls -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="12dp"
            android:paddingRight="12dp">

            <TextView
                android:id="@+id/cartItemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Item Name"
                android:textColor="@color/navy"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_semibold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/cartItemPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="$0.00"
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                android:fontFamily="@font/poppins" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/cartBtnDecrease"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:text="−"
                    android:gravity="center"
                    android:textColor="@color/navy"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_bold"
                    android:background="@drawable/qty_btn_outline"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/cartItemQuantity"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:gravity="center"
                    android:textColor="@color/navy"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:id="@+id/cartBtnIncrease"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:text="+"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_bold"
                    android:background="@drawable/qty_btn_filled"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </LinearLayout>

        <!-- Right: remove button + item total -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/cartBtnRemove"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_remove"
                android:padding="4dp"
                app:tint="@color/gray_text"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Remove item" />

            <TextView
                android:id="@+id/cartItemTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="$0.00"
                android:textColor="@color/sky"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_bold" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
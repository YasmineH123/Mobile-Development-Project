<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- TOP BAR — fixed height, nothing clips on small screens -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/navy"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:elevation="6dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:padding="10dp"
            android:background="@drawable/ripple_circle_light"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/toolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="FLY"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_semibold"
            android:letterSpacing="0.15" />

        <!-- Cart button: larger touch target so it works on small phones -->
        <ImageView
            android:id="@+id/btnCart"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_cart"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:padding="10dp"
            android:background="@drawable/ripple_circle_light"
            android:contentDescription="Cart"
            android:clickable="true"
            android:focusable="true" />

    </RelativeLayout>

    <!-- SCROLL BODY -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- HERO IMAGE -->
            <ImageView
                android:id="@+id/imgFoodDetail"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:scaleType="centerCrop"
                android:background="@color/pale_blue"
                android:contentDescription="Food image" />

            <!-- FLOATING CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-32dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="24dp"
                    android:paddingRight="24dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="8dp">

                    <!-- NAME + PRICE -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvFoodName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Product Name"
                            android:textColor="@color/navy"
                            android:textSize="20sp"
                            android:fontFamily="@font/poppins_bold"
                            android:maxLines="2"
                            android:lineSpacingMultiplier="1.2" />

                        <TextView
                            android:id="@+id/tvFoodPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="$0.00"
                            android:textColor="@color/sky"
                            android:textSize="20sp"
                            android:fontFamily="@font/poppins_bold" />

                    </LinearLayout>

                    <!-- RATING + CATEGORY -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <TextView
                            android:id="@+id/tvFoodRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 4.9"
                            android:textColor="@color/ocean"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_semibold" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="16dp"
                            android:layout_marginLeft="12dp"
                            android:layout_marginRight="12dp"
                            android:background="@color/light_blue" />

                        <TextView
                            android:id="@+id/tvFoodCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category"
                            android:textColor="@color/gray_text"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins" />

                    </LinearLayout>

                    <!-- DIVIDER -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp"
                        android:background="@color/pale_blue" />

                    <!-- DESCRIPTION -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textColor="@color/navy"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold" />

                    <TextView
                        android:id="@+id/tvFoodDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Description goes here"
                        android:textColor="@color/gray_text"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins"
                        android:lineSpacingMultiplier="1.7" />

                    <!-- DIVIDER -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp"
                        android:background="@color/pale_blue" />

                    <!-- INGREDIENTS -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ingredients"
                        android:textColor="@color/navy"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupIngredients"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:chipSpacingHorizontal="6dp"
                        app:chipSpacingVertical="6dp" />

                    <!-- DIVIDER -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp"
                        android:background="@color/pale_blue" />

                    <!-- QUANTITY + ADD TO CART -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quantity"
                                android:textColor="@color/navy"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_semibold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="12dp">

                                <TextView
                                    android:id="@+id/btnDecrease"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:text="−"
                                    android:gravity="center"
                                    android:textColor="@color/navy"
                                    android:textSize="22sp"
                                    android:fontFamily="@font/poppins_bold"
                                    android:background="@drawable/qty_btn_outline"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <TextView
                                    android:id="@+id/tvQuantity"
                                    android:layout_width="48dp"
                                    android:layout_height="wrap_content"
                                    android:text="1"
                                    android:gravity="center"
                                    android:textColor="@color/navy"
                                    android:textSize="20sp"
                                    android:fontFamily="@font/poppins_bold" />

                                <TextView
                                    android:id="@+id/btnIncrease"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:text="+"
                                    android:gravity="center"
                                    android:textColor="@color/white"
                                    android:textSize="22sp"
                                    android:fontFamily="@font/poppins_bold"
                                    android:background="@drawable/qty_btn_filled"
                                    android:clickable="true"
                                    android:focusable="true" />

                            </LinearLayout>
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnAddToCart"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1.3"
                            android:layout_marginStart="20dp"
                            android:text="Add to Cart"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:backgroundTint="@color/navy"
                            app:cornerRadius="18dp"
                            android:elevation="4dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
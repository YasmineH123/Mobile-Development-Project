<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ✅ SHARED TOOLBAR (same line all teammates use) -->
    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_main" />

    <!-- ✅ SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ✅ HEADER: greeting + subtitle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"
                android:background="@color/navy">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What would you like?"
                    android:textColor="@color/pale_blue"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Order Your Food 🍔"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:fontFamily="@font/poppins_bold" />

            </LinearLayout>

            <!-- ✅ SEARCH BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:background="@color/navy">

                <EditText
                    android:id="@+id/searchBar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Search for food..."
                    android:hintTextColor="@color/light_blue"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/search_bar_bg"
                    android:drawableStart="@drawable/ic_search"
                    android:drawablePadding="8dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch" />

            </LinearLayout>

            <!-- ✅ WAVE DIVIDER: navy to white transition -->
            <View
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:background="@color/navy" />

            <!-- ✅ CATEGORY CHIP TABS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="12dp"
                android:paddingVertical="12dp">

                <LinearLayout
                    android:id="@+id/categoryChipsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />

            </HorizontalScrollView>

            <!-- ✅ FEATURED / POPULAR SECTION HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔥 Featured"
                    android:textColor="@color/navy"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:id="@+id/seeAllFeatured"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="@color/sky"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins" />

            </LinearLayout>

            <!-- ✅ FEATURED: HORIZONTAL SCROLL ROW -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="12dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:id="@+id/featuredContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

            <!-- ✅ ALL PRODUCTS SECTION HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/allProductsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="All Products"
                    android:textColor="@color/navy"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold" />

            </LinearLayout>

            <!-- ✅ PRODUCTS 2-COLUMN GRID -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/productsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>